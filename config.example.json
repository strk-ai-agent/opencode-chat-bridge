{
  "$schema": "./config.schema.json",

  "toolMessages": {
    "mode": "events",
    "showCalls": true,
    "showArguments": false,
    "showOutputFor": ["bash"],
    "maxTraceEntries": 20
  },
  
  "matrix": {
    "enabled": true,
    "homeserver": "https://matrix.org",
    "userId": "@your-bot:matrix.org",
    "accessToken": "{env:MATRIX_ACCESS_TOKEN}",
    "deviceId": "OPENCODE_BRIDGE",
    
    "encryption": {
      "enabled": false,
      "storePath": "./matrix-store/"
    },
    
    "autoJoin": true,
    
    "triggerPatterns": [
      "@your-bot:",
      "!oc "
    ],
    
    "ignoreRooms": [],
    "ignoreUsers": []
  },
  
  "mattermost": {
    "enabled": false,
    "url": "{env:MATTERMOST_URL}",
    "token": "{env:MATTERMOST_TOKEN}",
    "teamName": "",
    "respondToMentions": true,
    "ignoreChannels": [],
    "ignoreUsers": []
  },

  "discord": {
    "enabled": false,
    "token": "{env:DISCORD_TOKEN}"
  },

  "telegram": {
    "enabled": false,
    "token": "{env:TELEGRAM_BOT_TOKEN}",
    "respondToMentions": true,
    "threadIsolation": true,
    "respondToReplies": true,
    "attachments": {
      "enabled": true,
      "maxFileBytes": 20971520,
      "maxFilesPerMessage": 4
    },
    "ignoreChats": [],
    "ignoreUsers": [],
    "allowedUsers": []
  },

  "irc": {
    "enabled": false,
    "server": "irc.libera.chat",
    "nick": "opencode-bot",
    "channels": ["#your-channel"]
  },
  
  "sessionStorePath": "./.opencode/chat-sessions.json",
  "acp": {
    "command": "opencode",
    "args": ["acp"],
    "backendId": "opencode",
    "profileDir": ""
  },
  "defaultAgent": null
}
